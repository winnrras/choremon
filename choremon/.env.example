# Anthropic API Key for Claude Vision (optional, tried first)
ANTHROPIC_API_KEY=your_api_key_here

# Gemini API Key for Google Vision (fallback if Claude unavailable)
GEMINI_API_KEY=your_gemini_api_key

# Public Gemini API Key for client-side Multimodal Live WebSocket
NEXT_PUBLIC_GEMINI_API_KEY=public_gemini_api
